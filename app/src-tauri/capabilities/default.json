{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core capabilities for the Cofounder main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:9119/*" },
        { "url": "http://localhost:9119/*" }
      ]
    }
  ]
}
